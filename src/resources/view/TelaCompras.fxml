<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TelaComprasController">
   <children>
      <VBox layoutX="200.0" layoutY="91.0" style="-fx-background-color: whi;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox VBox.vgrow="SOMETIMES">
               <children>
                  <VBox HBox.hgrow="SOMETIMES">
                     <children>
                        <Label style="-fx-text-fill: #1e293b; -fx-font-size: 26px; -fx-font-weight: bold;" text="Compras" VBox.vgrow="SOMETIMES" />
                     </children>
                  </VBox>
                  <VBox alignment="TOP_RIGHT" HBox.hgrow="SOMETIMES">
                     <children>
                        <Button fx:id="btnComprar" mnemonicParsing="false" onAction="#addCompra" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px;" text="Realizar Compra" VBox.vgrow="SOMETIMES" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <VBox style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);" VBox.vgrow="SOMETIMES">
               <children>
                  <Label style="-fx-background-size: 18px; -fx-text-fill: #1e293b; -fx-font-weight: bold;" text="Compras Realizadas:" />
                  <TableView fx:id="tableCompra" style="-fx-border-radius: 6px; -fx-background-color: white; -fx-border-color: #e2e8f0;" VBox.vgrow="SOMETIMES">
                    <columns>
                      <TableColumn fx:id="colCompras" prefWidth="75.0" text="ID da Compra" />
                      <TableColumn fx:id="colObs" prefWidth="75.0" text="Observações" />
                        <TableColumn fx:id="colValCom" prefWidth="75.0" text="Valor da Compra" />
                        <TableColumn fx:id="colAnex" prefWidth="75.0" text="Anexo Fiscal" />
                        <TableColumn fx:id="colDataCompra" prefWidth="75.0" text="Data da Compra" />
                        <TableColumn fx:id="colNPedido" prefWidth="75.0" text="N° Pedido" />
                        <TableColumn fx:id="colCriado" prefWidth="75.0" text="Criado Por" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <HBox VBox.vgrow="SOMETIMES">
                     <children>
                        <VBox alignment="CENTER_LEFT" HBox.hgrow="SOMETIMES">
                           <children>
                              <Button fx:id="btnExcluir" disable="true" mnemonicParsing="false" onAction="#excluirCompra" style="-fx-background-color: e60000; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 6px; -fx-cursor: hand; -fx-padding: 10px 20px; -fx-font-size: 14px;" text="Excluir" />
                           </children>
                        </VBox>
                        <VBox alignment="CENTER_RIGHT" HBox.hgrow="SOMETIMES">
                           <children>
                              <Button fx:id="btnAlterCons" disable="true" mnemonicParsing="false" onAction="#alterConsultar" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 6px; -fx-cursor: hand; -fx-padding: 10px 20px; -fx-font-size: 14px;" text="Alterar/Consultar" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
