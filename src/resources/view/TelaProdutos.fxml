<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f1f5f9; -fx-background: #f1f5f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TelaProdutosController">
    <content>
        <VBox spacing="25.0" style="-fx-padding: 30px;">
            <children>

                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Produtos" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#alterarVisibilidade" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 10px 20px; -fx-cursor: hand;" text="+ Cadastrar Produto" />
                    </children>
                </HBox>
                <VBox fx:id="vBoxCadProd" spacing="15.0" style="-fx-padding: 25px; -fx-background-radius: 12px; -fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" VBox.vgrow="SOMETIMES">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Cadastrar Novo Produto" />
                        <HBox spacing="15.0" VBox.vgrow="NEVER">
                            <children>
                                <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="SOMETIMES">
                                    <children>
                                        <Label text="Adicione imagem:" />
                                        <VBox alignment="CENTER" maxHeight="200.0" maxWidth="200.0" minHeight="200.0" minWidth="200.0" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: #e2e8f0; -fx-background-radius: 8px;">
                                            <children>
                                                <Label fx:id="txtImgNDefinida" alignment="CENTER" prefHeight="200.0" prefWidth="200.0" text="Insira a imagem" />
                                                <ImageView fx:id="imgNDefinida" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                            </children>
                                        </VBox>
                                        <Button mnemonicParsing="false" onAction="#colocarImg" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold;" text="Inserir Imagem" />
                                    </children>
                                </VBox>
                                <HBox HBox.hgrow="SOMETIMES">
                                    <children>
                                        <VBox spacing="30.0" HBox.hgrow="SOMETIMES">
                                            <children>
                                                <Label style="-fx-text-fill: #f71b1b;" text="* As informações abaixo são obrigatorias para cadastrar o produto" textFill="#f71b1b" />
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <VBox spacing="5.0">
                                                            <children>
                                                                <Label text="Nome do Produto:" />
                                                                <TextField fx:id="txtNomeProd" promptText="Produto" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                                                            <children>
                                                                <Label text="Preço:" />
                                                                <TextField fx:id="txtPreco" promptText="Apenas números aqui" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                                                            <children>
                                                                <Label text="Quantidade:" />
                                                                <TextField fx:id="txtQuant" promptText="Apenas números aqui" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                                                            <children>
                                                                <Label text="Minimo no Estoque:" />
                                                                <TextField fx:id="txtMinEs" promptText="Apenas números aqui" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                                                            <children>
                                                                <Label text="Categoria:" />
                                                                <HBox alignment="CENTER_LEFT" spacing="5.0">
                                                                    <children>
                                                                        <ComboBox fx:id="comboCat" maxWidth="1.7976931348623157E308" promptText="Selecione a Categoria do Produto" HBox.hgrow="ALWAYS" />
                                                                        <Button onAction="#alternarNovaCategoria" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 6px 12px; -fx-cursor: hand;" text="+" />
                                                                    </children>
                                                                </HBox>
                                                                <VBox fx:id="vboxNovaCategoria" managed="false" spacing="8.0" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 10px;" visible="false">
                                                                    <children>
                                                                        <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Nova Categoria:" />
                                                                        <TextField fx:id="txtNovaCategoria" promptText="Nome da categoria" />
                                                                        <HBox alignment="CENTER_RIGHT" spacing="8.0">
                                                                            <children>
                                                                                <Button onAction="#alternarNovaCategoria" style="-fx-background-color: transparent; -fx-text-fill: #64748b;" text="Cancelar" />
                                                                                <Button onAction="#salvarNovaCategoria" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 6px 14px;" text="Salvar" />
                                                                                <Button onAction="#removerCategoria" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 6px 12px; -fx-cursor: hand;" text="−" />
                                                                            </children>
                                                                        </HBox>
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                                                            <children>
                                                                <Label text="Fornecedor:" />
                                                                <ComboBox fx:id="comboFor" promptText="Selecione o Fornecedor do Produto" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </HBox>
                        <HBox alignment="BOTTOM_RIGHT">
                            <children>
                                <VBox>
                                    <children>
                                        <Button fx:id="buttonEnviar" alignment="BOTTOM_RIGHT" contentDisplay="CENTER" disable="true" mnemonicParsing="false" onAction="#enviarProd" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold;" text="Salvar Produto" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                    <cursor>
                        <Cursor fx:constant="DEFAULT" />
                    </cursor>
                </VBox>
                <VBox style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);" VBox.vgrow="SOMETIMES">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1e293b;" text="Comparação de valores">
                            <VBox.margin>
                                <Insets bottom="5.0" />
                            </VBox.margin>
                        </Label>
                  <Label style="-fx-text-fill: #1e293b;" text="Para comparar os produtos, selecione-os na tabela e clique no botão de &quot;Selecionar Produto&quot; respectivo.">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Label>
                        <HBox spacing="25.0" VBox.vgrow="SOMETIMES">
                            <children>
                                <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="SOMETIMES">
                                    <children>
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Produto:" />
                                                <Label fx:id="lblProduto1" text="NENHUM PRODUTO SELECIONADO" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Fornecedor:" />
                                                <Label fx:id="lblFornecedor1" text="NENHUM PRODUTO SELECIONADO" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Preço:" />
                                                <Label fx:id="lblPreco1" text="NENHUM PRODUTO SELECIONADO" />
                                            </children>
                                        </HBox>
                                        <Button fx:id="buttonSelecionar1" mnemonicParsing="false" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold;" text="Selecionar Produto" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="SOMETIMES">
                                    <children>
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Produto:" />
                                                <Label fx:id="lblProduto2" text="NENHUM PRODUTO SELECIONADO" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Fornecedor:" />
                                                <Label fx:id="lblFornecedor2" text="NENHUM PRODUTO SELECIONADO" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Preço:" />
                                                <Label fx:id="lblPreco2" text="NENHUM PRODUTO SELECIONADO" />
                                            </children>
                                        </HBox>
                                        <Button fx:id="buttonSelecionar2" mnemonicParsing="false" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold;" text="Selecionar Produto" />
                                    </children>
                                    <HBox.margin>
                                        <Insets />
                                    </HBox.margin>
                                </VBox>
                                <VBox alignment="TOP_CENTER" spacing="5.0" HBox.hgrow="SOMETIMES">
                                    <children>
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Mais Barato:" />
                                                <Label fx:id="lblMaisBarato" text="---" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Produto:" />
                                                <Label fx:id="lblProdutoBarato" text="---" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Preço:" />
                                                <Label fx:id="lblPrecoBarato" text="---" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox spacing="20.0">
                    <children>

                        <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);">
                            <children>
                                <VBox alignment="CENTER" prefHeight="268.0" style="-fx-background-color: #e2e8f0; -fx-background-radius: 8px;" VBox.vgrow="SOMETIMES">
                                    <children>
                                        <ImageView fx:id="imgProd" fitHeight="268.0" fitWidth="257.0" pickOnBounds="true" preserveRatio="true" VBox.vgrow="SOMETIMES" />
                                        <Label fx:id="txtNotFound" prefHeight="214.0" prefWidth="132.0" style="-fx-font-size: 80px; -fx-text-fill: #334155;" text="🖼️" VBox.vgrow="SOMETIMES" />
                                    </children>
                                </VBox>

                                <Label fx:id="texto_estoque" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1e293b;" text="Nenhum produto selecionado" />

                                <Label fx:id="texto_id_usuario" style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="---" wrapText="true" />

                                <Region VBox.vgrow="ALWAYS" />

                                <Button fx:id="historicoEst" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#abrirHistoricoEstoque" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 10px; -fx-cursor: hand;" text="Acessar Histórico Estoque ➔" />
                                <Button fx:id="gerenciarEst" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#botaoEstoque" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 10px; -fx-cursor: hand;" text="Gerenciar Estoque ➔" />
                            </children>
                        </VBox>

                        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);" HBox.hgrow="ALWAYS">
                            <children>

                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1e293b;" text="Produtos Cadastrados" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <TextField fx:id="txtNomePes" promptText="🔍 Buscar por Nome" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white; -fx-padding: 6px 15px;">
                                            <HBox.margin>
                                                <Insets right="5.0" />
                                            </HBox.margin></TextField>
                                        <TextField fx:id="txtNomeFornecedor1" promptText="🔍 Buscar por Fornecedor" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white; -fx-padding: 6px 15px;" />
                                    </children>
                                </HBox>

                                <TableView fx:id="tabelaProdutos" prefHeight="364.0" prefWidth="579.0" style="-fx-border-color: #e2e8f0; -fx-border-radius: 6px; -fx-background-color: white;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="columnId" prefWidth="36.0" text="ID" />
                                        <TableColumn fx:id="columnNome" prefWidth="138.0" text="NOME PRODUTO" />
                                        <TableColumn fx:id="columnPreco" prefWidth="66.0" text="PREÇO" />
                                        <TableColumn fx:id="columnQuantidade" prefWidth="101.0" text="QUANTIDADE" />
                                        <TableColumn fx:id="columnCategoria" prefWidth="110.0" text="CATEGORIA" />
                                        <TableColumn fx:id="columnFornecedor" prefWidth="124.0" text="FORNECEDOR" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                        <Pagination fx:id="prodpagination" maxPageIndicatorCount="5" pageCount="1000" prefHeight="28.0" prefWidth="579.0" />

                                <HBox />
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="buttonExcluir" contentDisplay="CENTER" mnemonicParsing="false" onAction="#excluirProduto" style="-fx-background-color: #e60000; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 8px 15px; -fx-cursor: hand;" text="Excluir Produto" />
                                        <Button fx:id="buttonEditarProduto" mnemonicParsing="false" onAction="#editarProduto" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 8px 15px; -fx-cursor: hand;" text="✏ Editar Produto" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER">
                                    <VBox.margin>
                                        <Insets bottom="20.0" top="20.0" />
                                    </VBox.margin>
                                </HBox>

                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
