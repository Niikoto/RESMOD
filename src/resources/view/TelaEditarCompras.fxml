<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="835.0" prefWidth="900.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TelaStatusPedidoController">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="750.0" prefWidth="750.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 35px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#voltarParaPedidos" style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand; -fx-padding: 6px 12px;" text="&lt; Voltar" />
                  <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Alterar informações de compras" />
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="55.0" prefWidth="680.0" spacing="100.0">
               <children>
                  <VBox prefHeight="200.0" prefWidth="200.0">
                     <children>
                        <Label fx:id="id_da_compra" prefWidth="200.0" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" text="ID da compra" />
                        <Label fx:id="valor_da_compra" text="VALOR DA COMPRA" />
                     </children>
                  </VBox>
                  <VBox prefHeight="200.0" prefWidth="200.0">
                     <children>
                        <Label fx:id="id_do_pedido" prefHeight="20.0" prefWidth="200.0" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" text="ID do pedido" />
                        <Label fx:id="valor_do_pedido" text="VALOR DO PEDIDO" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox fx:id="hBox_add_prod" spacing="15.0">
               <children>
                  <VBox HBox.hgrow="SOMETIMES">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" text="Editar valor da compra " />
                        <TextField prefHeight="25.0" prefWidth="573.0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox>
               <children>
                  <VBox fx:id="vBox_editar_motivo" HBox.hgrow="SOMETIMES">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" text="Editar observações" />
                        <TextArea fx:id="editar_motivo" prefHeight="81.0" prefWidth="680.0" promptText="(Opcional)" />
                        <VBox alignment="CENTER">
                           <children>
                              <HBox VBox.vgrow="SOMETIMES">
                                 <children>
                                    <VBox HBox.hgrow="SOMETIMES" />
                                    <VBox alignment="TOP_RIGHT" HBox.hgrow="SOMETIMES">
                                       <children>
                                          <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                             <padding>
                                                <Insets right="15.0" />
                                             </padding>
                                          </HBox>
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              <Label accessibleRole="PARENT" text="Selecione um arquivo fiscal:">
                                 <padding>
                                    <Insets bottom="10.0" top="10.0" />
                                 </padding>
                              </Label>
                              <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" spacing="10.0" style="-fx-background-color: #e2e8f0; -fx-background-radius: 8px;" VBox.vgrow="SOMETIMES">
                                 <children>
                                    <Label fx:id="txtArq" text="Nenhum Arquivo Selecionado" />
                                 </children>
                                 <VBox.margin>
                                    <Insets bottom="5.0" right="5.0" />
                                 </VBox.margin>
                              </VBox>
                              <Button mnemonicParsing="false" onAction="#selecioneArq" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold;" text="Selecionar Arquivo">
                                 <VBox.margin>
                                    <Insets bottom="20.0" />
                                 </VBox.margin>
                              </Button>
                              <VBox alignment="CENTER_LEFT" spacing="10.0" VBox.vgrow="SOMETIMES">
                                 <padding>
                                    <Insets right="5.0" />
                                 </padding>
                              </VBox>
                              <HBox spacing="10.0" VBox.vgrow="SOMETIMES">
                                 <children>
                                    <VBox alignment="CENTER_LEFT" HBox.hgrow="SOMETIMES" />
                                    <VBox alignment="CENTER_RIGHT" HBox.hgrow="SOMETIMES" />
                                 </children>
                                 <padding>
                                    <Insets top="10.0" />
                                 </padding>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="15.0" />
               </padding>
            </HBox>
            <HBox fx:id="hBox_status_pedido" VBox.vgrow="SOMETIMES">
               <children>
                  <VBox HBox.hgrow="SOMETIMES">
                     <children>
                        <HBox fx:id="hBoxButton" alignment="CENTER_RIGHT" spacing="15.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#voltarParaPedidos" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar" />
                              <Button mnemonicParsing="false" onAction="#definirNovoStatus" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand; -fx-padding: 10px 30px;" text="Confirmar Alterações" />
                           </children>
                           <VBox.margin>
                              <Insets top="15.0" />
                           </VBox.margin>
                        </HBox>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="15.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
