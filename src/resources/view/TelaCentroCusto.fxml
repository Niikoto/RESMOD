<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f1f5f9; -fx-background: #f1f5f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TelaCentroCustoController">
    <content>
        <VBox spacing="25.0" style="-fx-padding: 30px;">
            <children>

                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Controle de Gastos" />

                <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 25px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1e293b;" text="Filtrar por:" />
                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="Setor" />
                                        <ComboBox fx:id="comboSetor" maxWidth="1.7976931348623157E308" promptText="Todos os setores" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="Centro de Custo" />
                                        <ComboBox fx:id="comboCentroCusto" maxWidth="1.7976931348623157E308" promptText="Todos os centros de custo" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold; -fx-opacity: 0;" text="." />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button mnemonicParsing="false" onAction="#limparFiltro" style="-fx-background-color: transparent; -fx-border-color: #3b82f6; -fx-text-fill: #3b82f6; -fx-border-radius: 6px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8px 20px;" text="Limpar" />
                                                <Button mnemonicParsing="false" onAction="#aplicarFiltro" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand; -fx-padding: 8px 20px;" text="🔍 Filtrar" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox spacing="15.0">
                    <children>
                        <!-- total gasto por setor que for selecionado -->
                        <VBox alignment="CENTER" prefHeight="90.0" spacing="5.0"
                              style="-fx-background-color: #dbeafe; -fx-background-radius: 12px; -fx-padding: 15px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #1e40af; -fx-font-size: 13px; -fx-font-weight: bold;" text="Total Gasto — Setor" />
                                <Label fx:id="labelTotalSetor" style="-fx-text-fill: #1d4ed8; -fx-font-size: 22px; -fx-font-weight: bold;" text="R$ 0,00" />
                                <Label fx:id="labelNomeSetor" style="-fx-text-fill: #3b82f6; -fx-font-size: 12px;" text="(todos)" />
                            </children>
                        </VBox>

                        <!-- mesma coisa, so que com centro de custo selecionado -->
                        <VBox alignment="CENTER" prefHeight="90.0" spacing="5.0" style="-fx-background-color: #dcfce7; -fx-background-radius: 12px; -fx-padding: 15px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #166534; -fx-font-size: 13px; -fx-font-weight: bold;" text="Total Gasto — Centro de Custo" />
                                <Label fx:id="labelTotalCentro" style="-fx-text-fill: #15803d; -fx-font-size: 22px; -fx-font-weight: bold;" text="R$ 0,00" />
                                <Label fx:id="labelNomeCentro" style="-fx-text-fill: #22c55e; -fx-font-size: 12px;" text="(todos)" />
                            </children>
                        </VBox>

                        <!-- Quantidade de pedidos no filtro -->
                        <VBox alignment="CENTER" prefHeight="90.0" spacing="5.0"
                              style="-fx-background-color: #fef9c3; -fx-background-radius: 12px; -fx-padding: 15px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);"
                              HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #854d0e; -fx-font-size: 13px; -fx-font-weight: bold;" text="Pedidos Encontrados" />
                                <Label fx:id="labelQtdPedidos"
                                       style="-fx-text-fill: #a16207; -fx-font-size: 22px; -fx-font-weight: bold;"
                                       text="0" />
                                <Label fx:id="labelTotalTabela"
                                       style="-fx-text-fill: #a16207; -fx-font-size: 13px;"
                                       text="R$ 0,00" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Tabela de pedidos filtrados -->
                <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 25px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);" VBox.vgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1e293b;" text="Pedidos" />

                        <TableView fx:id="tablePedidos" prefHeight="350.0"
                                   style="-fx-border-color: #e2e8f0; -fx-border-radius: 6px; -fx-background-color: white;"
                                   VBox.vgrow="ALWAYS">
                            <placeholder>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-size: 36px; -fx-text-fill: #cbd5e1;" text="📄" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Selecione um filtro para ver os pedidos" />
                                    </children>
                                </VBox>
                            </placeholder>
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="80.0" text="N° Pedido" />
                                <TableColumn fx:id="colMotivo" prefWidth="180.0" text="Motivo" />
                                <TableColumn fx:id="colSetor" prefWidth="120.0" text="Setor" />
                                <TableColumn fx:id="colCentro" prefWidth="130.0" text="Centro de Custo" />
                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                                <TableColumn fx:id="colValor" prefWidth="110.0" text="Valor Total" />
                                <TableColumn fx:id="colCriado" prefWidth="100.0" text="Criado Em" />
                                <TableColumn fx:id="colCriadoPor" prefWidth="120.0" text="Criado Por" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>


                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
