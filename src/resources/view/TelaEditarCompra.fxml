<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TelaEditarCompraController">
    <children>
        <VBox spacing="15" style="-fx-background-color: #f1f5f9; -fx-padding: 30px;">
            <children>
                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Editar Compra" />

                <VBox spacing="5">
                    <Label style="-fx-text-fill: #475569; -fx-font-weight: bold;" text="Observações" />
                    <TextArea fx:id="campoObs" prefHeight="80" promptText="Observações" wrapText="true" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-text-fill: #475569; -fx-font-weight: bold;" text="Valor da Compra" />
                    <TextField fx:id="campoValor" promptText="0,00" />
                </VBox>

                <VBox spacing="5">
               <children>
                  <VBox alignment="CENTER">
                     <children>
                        <Label text="Arquivo Fiscal:" />
                        <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #e2e8f0; -fx-background-radius: 8px;" VBox.vgrow="SOMETIMES">
                           <children>
                              <Label fx:id="imgNotFound" text="Nenhum Arquivo Selecionado" />
                           </children>
                        </VBox>
                        <Button fx:id="btnSelecionar" mnemonicParsing="false" onAction="#selecArqu" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold;" text="Selecionar Arquivo">
                           <VBox.margin>
                              <Insets top="5.0" />
                           </VBox.margin>
                        </Button>
                     </children>
                  </VBox>
               </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button mnemonicParsing="false" onAction="#cancelar" style="-fx-background-color: transparent; -fx-border-color: #94a3b8; -fx-text-fill: #64748b; -fx-border-radius: 6px; -fx-padding: 8px 20px; -fx-cursor: hand;" text="Cancelar" />
                    <Button mnemonicParsing="false" onAction="#salvar" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 8px 20px; -fx-cursor: hand;" text="Salvar" />
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
