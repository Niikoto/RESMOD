<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f1f5f9; -fx-background: #f1f5f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TelaFornecedoresController">
    <content>
        <VBox spacing="25.0" style="-fx-padding: 30px;">
            <children>

                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Fornecedores" />

                <VBox spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 25px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1e293b;" text="Pesquisar por:" />

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="Código (ID)" />
                                        <TextField promptText="Ex.: 00123" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white; -fx-padding: 8px;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="Nome" />
                                        <TextField promptText="Nome do fornecedor" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white; -fx-padding: 8px;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="CPF" />
                                        <TextField promptText="000.000.000-00" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white; -fx-padding: 8px;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="CNPJ" />
                                        <TextField promptText="00.000.000/0000-00" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white; -fx-padding: 8px;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="BOTTOM_LEFT" spacing="15.0">
                            <children>
                                <VBox spacing="5.0" prefWidth="200.0">
                                    <children>
                                        <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="Estado" />
                                        <ComboBox maxWidth="1.7976931348623157E308" promptText="Selecione" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" prefWidth="200.0">
                                    <children>
                                        <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="Município" />
                                        <ComboBox maxWidth="1.7976931348623157E308" promptText="Selecione" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white;" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <Button mnemonicParsing="false" style="-fx-background-color: transparent; -fx-border-color: #3b82f6; -fx-text-fill: #3b82f6; -fx-border-radius: 6px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8px 20px;" text="Limpar" />
                                <Button mnemonicParsing="false" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand; -fx-padding: 8px 20px;" text="🔍 Pesquisar" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 25px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);" VBox.vgrow="ALWAYS">
                    <children>

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1e293b;" text="Todos os Registros" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand; -fx-padding: 8px 15px;" text="+ Adicionar Fornecedor" />
                            </children>
                        </HBox>

                        <TableView fx:id="tabelaFornecedores" prefHeight="300.0" style="-fx-border-color: #e2e8f0; -fx-border-radius: 6px; -fx-background-color: white;" VBox.vgrow="ALWAYS">

                            <placeholder>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-size: 40px; -fx-text-fill: #cbd5e1;" text="📄" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Não há resultados na tabela" />
                                    </children>
                                </VBox>
                            </placeholder>

                            <columns>
                                <TableColumn prefWidth="60.0" text="ID" />
                                <TableColumn prefWidth="150.0" text="NOME" />
                                <TableColumn prefWidth="120.0" text="CPF" />
                                <TableColumn prefWidth="120.0" text="CNPJ" />
                                <TableColumn prefWidth="100.0" text="ESTADO" />
                                <TableColumn prefWidth="150.0" text="MUNICÍPIO" />
                                <TableColumn prefWidth="120.0" text="TELEFONE" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="0 registros encontrados" />
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox spacing="5.0">
                                    <children>
                                        <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 4px; -fx-text-fill: #94a3b8; -fx-cursor: hand;" text="&lt;" />
                                        <Button mnemonicParsing="false" style="-fx-background-color: #eff6ff; -fx-border-color: #bfdbfe; -fx-border-radius: 4px; -fx-text-fill: #2563eb; -fx-font-weight: bold; -fx-cursor: hand;" text="1" />
                                        <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 4px; -fx-text-fill: #94a3b8; -fx-cursor: hand;" text="&gt;" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>