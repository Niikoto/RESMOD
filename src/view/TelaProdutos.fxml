<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f1f5f9; -fx-background: #f1f5f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TelaProdutosController">
    <content>
        <VBox spacing="25.0" style="-fx-padding: 30px;">
            <children>

                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Produtos" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#alterarVisibilidade" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 10px 20px; -fx-cursor: hand;" text="+ Cadastrar Produto" />
                    </children>
                </HBox>
            <VBox fx:id="vBoxCadProd" spacing="15.0" style="-fx-padding: 25px; -fx-background-radius: 12px; -fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" VBox.vgrow="SOMETIMES">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Cadastrar Novo Produto" />
                  <HBox spacing="15.0" VBox.vgrow="NEVER">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                           <children>
                              <Label text="Nome do Produto:" />
                              <TextField fx:id="txtNomeProd" promptText="Produto" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                           <children>
                              <Label text="Preço:" />
                              <TextField fx:id="txtPreco" promptText="Apenas números aqui" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                           <children>
                              <Label text="Quantidade:" />
                              <TextField fx:id="txtQuant" promptText="Apenas números aqui"/>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <HBox spacing="15.0">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                           <children>
                              <Label text="Minimo no Estoque:" />
                              <TextField fx:id="txtMinEs" promptText="Apenas números aqui" />
                           </children>
                        </VBox>
                         <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                             <children>
                                 <Label text="Categoria:" />
                                 <HBox spacing="5.0" alignment="CENTER_LEFT">
                                     <children>
                                         <ComboBox fx:id="comboCat" promptText="Selecione a Categoria do Produto" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
                                         <Button text="+" onAction="#alternarNovaCategoria"
                                                 style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 6px 12px; -fx-cursor: hand;" />
                                     </children>
                                 </HBox>
                                 <VBox fx:id="vboxNovaCategoria" spacing="8.0" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 10px;" managed="false" visible="false">
                                     <children>
                                         <Label text="Nova Categoria:" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                                         <TextField fx:id="txtNovaCategoria" promptText="Nome da categoria" />
                                         <HBox spacing="8.0" alignment="CENTER_RIGHT">
                                             <children>
                                                 <Button text="Cancelar" onAction="#alternarNovaCategoria"
                                                         style="-fx-background-color: transparent; -fx-text-fill: #64748b;" />
                                                 <Button text="Salvar" onAction="#salvarNovaCategoria"
                                                         style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 6px 14px;" />
                                                 <Button text="−" onAction="#removerCategoria"
                                                         style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 6px 12px; -fx-cursor: hand;" />
                                             </children>
                                         </HBox>
                                     </children>
                                 </VBox>
                             </children>
                         </VBox>
                        <VBox spacing="5.0" HBox.hgrow="SOMETIMES">
                           <children>
                              <Label text="Fornecedor:" />
                              <ComboBox fx:id="comboFor" promptText="Selecione o Fornecedor do Produto" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <HBox alignment="BOTTOM_RIGHT">
                     <children>
                        <VBox>
                           <children>
                              <Button fx:id="buttonEnviar" alignment="BOTTOM_RIGHT" contentDisplay="CENTER" mnemonicParsing="false" onAction="#enviarProd" style="-fx-background-color: #49b69b; -fx-text-fill: white; -fx-font-weight: bold;" text="Salvar Produto" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
            </VBox>

                <HBox spacing="20.0">
                    <children>

                        <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);">
                            <children>
                                <VBox alignment="CENTER" prefHeight="220.0" style="-fx-background-color: #e2e8f0; -fx-background-radius: 8px;">
                                    <children>
                                        <Label style="-fx-font-size: 80px; -fx-text-fill: #334155;" text="🖼️" />
                                    </children>
                                </VBox>

                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1e293b;" text="Carregador de Celular" />

                                <Label style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" text="Adicionado em: YYYY-MM-DD&#10;por USUÁRIO X" wrapText="true" />

                                <Region VBox.vgrow="ALWAYS" />

                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 10px; -fx-cursor: hand;" text="Gerenciar Estoque ➔" />
                            </children>
                        </VBox>

                        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 0);" HBox.hgrow="ALWAYS">
                            <children>

                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1e293b;" text="Produtos Cadastrados" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <TextField promptText="🔍 Buscar por ID" style="-fx-background-radius: 6px; -fx-border-color: #cbd5e1; -fx-border-radius: 6px; -fx-background-color: white; -fx-padding: 6px 15px;" />
                                    </children>
                                </HBox>

                                <TableView fx:id="tabelaProdutos" prefHeight="250.0" style="-fx-border-color: #e2e8f0; -fx-border-radius: 6px; -fx-background-color: white;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn prefWidth="75.0" text="ITEM" />
                                        <TableColumn prefWidth="150.0" text="NOME PRODUTO" />
                                        <TableColumn prefWidth="100.0" text="PREÇO" />
                                        <TableColumn prefWidth="100.0" text="QUANTIDADE" />
                                        <TableColumn prefWidth="100.0" text="MARCA" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                                <HBox>
                                    <children>
                                        <TextField promptText="Buscar por ID" style="-fx-background-color: #e2e8f0; -fx-background-radius: 6px; -fx-padding: 6px 10px; -fx-text-fill: #64748b; -fx-border-color: transparent;" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER">
                                    <children>
                                        <Label style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-font-size: 24px;" text="(INCLUIR MAIS FUNCIONALIDADES)" />
                                    </children>
                                    <VBox.margin>
                                        <Insets bottom="20.0" top="20.0" />
                                    </VBox.margin>
                                </HBox>

                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
